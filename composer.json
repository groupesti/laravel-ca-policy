{
    "name": "groupesti/laravel-ca-policy",
    "description": "Certificate Policy, CPS, name constraints, and issuance rules for Laravel CA",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^0.1",
        "groupesti/laravel-ca-crt": "^0.1",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/console": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/routing": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Policy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Policy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Policy\\PolicyServiceProvider"
            ],
            "aliases": {
                "CaPolicy": "CA\\Policy\\Facades\\CaPolicy"
            }
        }
    },
    "minimum-stability": "stable"
}
